        <!-- VPC Container -->
        <mxCell id="c_vpc" value="Virtual Private Cloud (VPC)" style="fillColor=rgba(15,23,42,0.2);strokeColor=#0284C7;strokeWidth=1.5;dashed=1;rounded=1;labelBackgroundColor=none;fontColor=#38BDF8;fontStyle=1;fontSize=12;align=left;spacingLeft=15;verticalAlign=top;spacingTop=10;fontFamily=Inter,Helvetica;" vertex="1" parent="1">
          <mxGeometry x="140" y="110" width="820" height="630" as="geometry" />
        </mxCell>

        <!-- Public Subnet Container -->
        <mxCell id="c_subnet" value="Public Subnet (Internet-Facing Segment)" style="fillColor=rgba(15,23,42,0.3);strokeColor=#0369A1;strokeWidth=1.5;dashed=1;rounded=1;labelBackgroundColor=none;fontColor=#0EA5E9;fontStyle=1;fontSize=12;align=left;spacingLeft=15;verticalAlign=top;spacingTop=10;fontFamily=Inter,Helvetica;" vertex="1" parent="1">
          <mxGeometry x="180" y="170" width="740" height="540" as="geometry" />
        </mxCell>

        <!-- EC2 Container -->
        <mxCell id="c_ec2" value="Amazon EC2 Compute Instance (Ubuntu 22.04 LTS)" style="fillColor=rgba(30,41,59,0.3);strokeColor=#F97316;strokeWidth=2;dashed=0;rounded=1;labelBackgroundColor=none;fontColor=#FB923C;fontStyle=1;fontSize=13;align=left;spacingLeft=15;verticalAlign=top;spacingTop=10;fontFamily=Inter,Helvetica;" vertex="1" parent="1">
          <mxGeometry x="220" y="220" width="660" height="460" as="geometry" />
        </mxCell>

        <!-- Nginx Web Server -->
        <mxCell id="n_nginx" value="&lt;b&gt;Nginx Web Server&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;2&quot; color=&quot;#94A3B8&quot;&gt;Listens on Port 80 (HTTP)&lt;br/&gt;Performs Reverse Proxy&lt;br/&gt;Enables WS Upgrades&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#F97316;strokeWidth=2;fontColor=#F8FAFC;fontFamily=Inter,Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="450" y="270" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- systemd service -->
        <mxCell id="n_systemd" value="&lt;b&gt;systemd supervisor&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;2&quot; color=&quot;#94A3B8&quot;&gt;Manages workoop.service&lt;br/&gt;Auto-restarts on failure&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#475569;strokeWidth=1.5;fontColor=#E2E8F0;fontFamily=Inter,Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="250" y="270" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Executable JAR Process -->
        <mxCell id="n_jar" value="&lt;b&gt;Spring Boot Application Process&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;2&quot; color=&quot;#E2E8F0&quot;&gt;&lt;i&gt;ExecStart: java -jar ptkt-backend-1.0.0.jar&lt;/i&gt;&lt;/font&gt;&lt;br/&gt;&lt;font size=&quot;2&quot; color=&quot;#94A3B8&quot;&gt;Runs at local Port 48080 (embedded Tomcat)&lt;br/&gt;Combines backend controllers and compiled Vue 3 static assets&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#F97316;strokeWidth=2;fontColor=#F8FAFC;fontFamily=Inter,Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="420" y="370" width="280" height="90" as="geometry" />
        </mxCell>

        <!-- Config env file -->
        <mxCell id="n_env" value="&lt;b&gt;Environment Variables&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;2&quot; color=&quot;#94A3B8&quot;&gt;/etc/workoop.env&lt;br/&gt;(GROQ_API_KEY, secrets)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#475569;strokeWidth=1.5;fontColor=#CBD5E1;fontFamily=Inter,Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="250" y="385" width="150" height="60" as="geometry" />
        </mxCell>

        <!-- Local Block Storage EBS Container -->
        <mxCell id="c_storage_files" value="Local Instance Storage (Amazon EBS Directories)" style="fillColor=rgba(15,23,42,0.4);strokeColor=#10B981;strokeWidth=1.5;dashed=1;rounded=1;labelBackgroundColor=none;fontColor=#34D399;fontStyle=1;fontSize=12;align=left;spacingLeft=15;verticalAlign=top;spacingTop=10;fontFamily=Inter,Helvetica;" vertex="1" parent="1">
          <mxGeometry x="250" y="490" width="600" height="160" as="geometry" />
        </mxCell>

        <!-- H2 DB File -->
        <mxCell id="n_h2_file" value="&lt;b&gt;H2 Relational Database File&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;2&quot; color=&quot;#94A3B8&quot;&gt;/home/ubuntu/workoop-data/ptkt-db.mv.db&lt;br/&gt;&lt;i&gt;Runs with AUTO_SERVER=TRUE&lt;br/&gt;mode=MySQL dialect compatibility&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#10B981;strokeWidth=2;fontColor=#F8FAFC;fontFamily=Inter,Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="280" y="550" width="250" height="80" as="geometry" />
        </mxCell>

        <!-- Jena TDB2 Directory -->
        <mxCell id="n_jena_dir" value="&lt;b&gt;Apache Jena TDB2 Folder&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;2&quot; color=&quot;#94A3B8&quot;&gt;/home/ubuntu/workoop/data/jena-tdb/&lt;br/&gt;&lt;i&gt;RDF triple index files&lt;br/&gt;(SPO, journal.jrnl, nodes.dat)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#10B981;strokeWidth=2;fontColor=#F8FAFC;fontFamily=Inter,Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="560" y="550" width="260" height="80" as="geometry" />
        </mxCell>


        <!-- 2. Client Side Entities (Outside VPC) -->
        <mxCell id="n_browser" value="&lt;b&gt;User Web Browser&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;2&quot; color=&quot;#94A3B8&quot;&gt;Accesses http://&amp;lt;EC2-IP&amp;gt;&lt;br/&gt;Loads Vue 3 JS &amp;amp; CSS&lt;br/&gt;Executes REST &amp;amp; live WS&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#3B82F6;strokeWidth=2;fontColor=#F8FAFC;fontFamily=Inter,Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="-160" y="260" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="n_igw" value="&lt;b&gt;Internet Gateway&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;2&quot; color=&quot;#94A3B8&quot;&gt;Route 53 Routing &amp;amp;&lt;br/&gt;AWS Internet Gateway&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#475569;strokeWidth=1.5;fontColor=#CBD5E1;fontFamily=Inter,Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="-10" y="190" width="120" height="60" as="geometry" />
        </mxCell>


        <!-- 3. External API Clouds -->
        <mxCell id="n_groq_cloud" value="&lt;b&gt;Groq Cloud Platform&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;2&quot; color=&quot;#94A3B8&quot;&gt;https://api.groq.com/&lt;br/&gt;Inference API for Groq LLM&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#EF4444;strokeWidth=2;fontColor=#F8FAFC;fontFamily=Inter,Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="1040" y="270" width="180" height="70" as="geometry" />
        </mxCell>

        <mxCell id="n_slack_cloud" value="&lt;b&gt;Slack API SaaS Cloud&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;2&quot; color=&quot;#94A3B8&quot;&gt;https://slack.com/&lt;br/&gt;Accepts webhook messages&lt;br/&gt;for team Slack channels&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#EF4444;strokeWidth=2;fontColor=#F8FAFC;fontFamily=Inter,Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="1040" y="380" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- ========================================== -->
        <!-- CONNECTIONS (Page 2)                       -->
        <!-- ========================================== -->

        <!-- Browser to Route 53 / IGW -->
        <mxCell id="e_inf1" value="HTTP (Port 80) / WS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3B82F6;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="n_browser" target="n_igw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- IGW to Nginx -->
        <mxCell id="e_inf2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3B82F6;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="n_igw" target="n_nginx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Nginx to Spring Boot JAR -->
        <mxCell id="e_inf3" value="Proxy Pass to localhost:48080" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#F97316;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="n_nginx" target="n_jar">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- systemd manages Spring Boot JAR -->
        <mxCell id="e_inf4" value="Spawns Java process" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#475569;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="n_systemd" target="n_jar">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Env file loaded by systemd -->
        <mxCell id="e_inf5" value="Injects variables" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#475569;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="n_env" target="n_systemd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Spring Boot process reads/writes to Relational Database H2 -->
        <mxCell id="e_inf6" value="JDBC Queries" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#10B981;strokeWidth=2;endArrow=classic;exitX=0.25;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;" edge="1" parent="1" source="n_jar" target="n_h2_file">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Spring Boot process reads/writes to Jena ontology directories -->
        <mxCell id="e_inf7" value="Jena TDB2 operations" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#10B981;strokeWidth=2;endArrow=classic;exitX=0.75;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;" edge="1" parent="1" source="n_jar" target="n_jena_dir">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Spring Boot connects to Groq AI -->
        <mxCell id="e_inf8" value="HTTPS REST Model Call" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#EF4444;strokeWidth=1.5;endArrow=classic;exitX=1;exitY=0.25;entryX=0;entryY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="n_jar" target="n_groq_cloud">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Spring Boot connects to Slack Webhook -->
        <mxCell id="e_inf9" value="HTTPS Slack Webhook Call" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#EF4444;strokeWidth=1.5;endArrow=classic;exitX=1;exitY=0.75;entryX=0;entryY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="n_jar" target="n_slack_cloud">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
