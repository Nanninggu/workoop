<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ptkt.mapper.UserMapper">

    <resultMap id="userResultMap" type="com.ptkt.model.User">
        <id     property="id"        column="id"/>
        <result property="email"     column="email"/>
        <result property="password"  column="password"/>
        <result property="name"      column="name"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findByEmail" resultMap="userResultMap">
        SELECT * FROM users WHERE email = #{email}
    </select>

    <select id="findById" resultMap="userResultMap">
        SELECT * FROM users WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.ptkt.model.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (email, password, name, created_at)
        VALUES (#{email}, #{password}, #{name}, CURRENT_TIMESTAMP)
    </insert>

</mapper>
